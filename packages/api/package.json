{
  "name": "@coffee-companion/api",
  "private": true,
  "type": "module",
  "scripts": {
    "typecheck": "tsc --noEmit",
    "lint": "eslint",
    "test": "vitest run",
    "test:coverage": "vitest run --config vitest.integration.config.ts --coverage",
    "test:integration": "vitest run --config vitest.integration.config.ts",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:push": "drizzle-kit push",
    "db:pull": "drizzle-kit pull",
    "db:studio": "drizzle-kit studio",
    "db:seed": "tsx src/db/seed.ts",
    "db:docs": "dotenv -e .env.local -- tbls doc --rm-dist --force"
  },
  "exports": {
    "./trpc/router": "./src/trpc/router.ts",
    "./trpc/init": "./src/trpc/init.ts",
    "./db": "./src/db/index.ts",
    "./db/schema": "./src/db/schema.ts",
    "./db/seed-e2e": "./src/db/seed-e2e.ts",
    "./db/zod": "./src/db/zod.ts",
    "./lib/auth": "./src/lib/auth.ts",
    "./lib/e2e-auth": "./src/lib/e2e-auth.ts",
    "./lib/espresso": "./src/lib/espresso.ts",
    "./lib/aeropress": "./src/lib/aeropress.ts",
    "./lib/pourover": "./src/lib/pourover.ts",
    "./lib/frenchpress": "./src/lib/frenchpress.ts",
    "./lib/cold-brew": "./src/lib/cold-brew.ts"
  },
  "dependencies": {
    "@trpc/server": "^11.8.1",
    "better-auth": "^1.4.10",
    "dotenv": "^17.2.3",
    "drizzle-orm": "1.0.0-beta.18-7eb39f0",
    "drizzle-zod": "^0.8.3",
    "pg": "^8.16.3",
    "superjson": "^2.2.6",
    "zod": "^4.3.5"
  },
  "devDependencies": {
    "@tanstack/eslint-config": "^0.3.4",
    "@types/pg": "^8.16.0",
    "dotenv-cli": "^11.0.0",
    "eslint": "^10.5.0",
    "globals": "^16.5.0",
    "drizzle-kit": "1.0.0-beta.18-7eb39f0",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vitest": "^4.1.9",
    "@vitest/coverage-v8": "^4.1.9"
  }
}
